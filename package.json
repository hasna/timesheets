{
  "name": "@hasna/timesheets",
  "version": "0.1.0",
  "description": "Timesheet management for AI agents — track projects, log time entries, and generate summaries via CLI + MCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "timesheets": "dist/cli/index.js",
    "timesheets-mcp": "dist/mcp/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist/cli --target bun --external @modelcontextprotocol/sdk && bun build src/mcp/index.ts --outdir dist/mcp --target bun --external @modelcontextprotocol/sdk && bun build src/index.ts --outdir dist --target bun && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun run src/cli/index.ts",
    "dev:mcp": "bun run src/mcp/index.ts",
    "prepublishOnly": "bun run build",
    "postinstall": "mkdir -p $HOME/.hasna/timesheets 2>/dev/null || true"
  },
  "keywords": [
    "timesheets",
    "time-tracking",
    "mcp",
    "ai",
    "coding-agent",
    "claude",
    "cli",
    "sqlite"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/open-timesheets.git"
  },
  "homepage": "https://github.com/hasna/open-timesheets",
  "bugs": {
    "url": "https://github.com/hasna/open-timesheets/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": "Andrei Hasna <andrei@hasna.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@hasna/cloud": "^0.1.24",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  }
}
